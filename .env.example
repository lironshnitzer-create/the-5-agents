# ========================================
#  קובץ תבנית למשתני סביבה (env.example)
#  העתק קובץ זה ל-.env ומלא את הערכים האמיתיים.
#  אל תעלה את .env ל-git! (הוא מוגן ב-.gitignore)
# ========================================

# ===== Anthropic / Claude =====
# מפתח ה-API של Anthropic — נדרש להפעלת הסוכנים (ראובן, יעל, יובל, חן)
ANTHROPIC_API_KEY=

# ===== מחקר (חן) =====
# מפתח לשירות חיפוש/איסוף מידע (לדוגמה: Tavily, Brave, SerpAPI)
SEARCH_API_KEY=

# ===== עיצוב תמונות (יובל) =====
# מפתח לשירות יצירת תמונות
IMAGE_API_KEY=
